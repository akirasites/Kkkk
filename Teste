-- Sistema duplicação perfeita
DupButton.MouseButton1Click:Connect(function()
	local character = player.Character or player.CharacterAdded:Wait()
	local tool = character:FindFirstChildOfClass("Tool")
	
	if tool then
		local clone = tool:Clone()
		clone.Name = tool.Name
		clone.Parent = player.Backpack
		
		-- Reinicia todos scripts internos
		for _, obj in pairs(clone:GetDescendants()) do
			if obj:IsA("Script") or obj:IsA("LocalScript") then
				obj.Disabled = true
				obj.Disabled = false
			end
		end
	end
end)

-- RGB rodapé
local clicks = 0
local active = false

Footer.MouseButton1Click:Connect(function()
	clicks += 1
	if clicks >= 5 and not active then
		clicks = 0
		active = true
		local endTime = tick() + 5
		task.spawn(function()
			while tick() < endTime do
				Footer.TextColor3 = Color3.fromHSV((tick()%5)/5,1,1)
				task.wait(0.05)
			end
			Footer.TextColor3 = Color3.fromRGB(180,180,180)
			active = false
		end)
	end
end)
